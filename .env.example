# Local dev: copy to .env and adjust if your backend runs on another port.
# Production (Vercel): set VITE_API_BASE_URL in the project's
#   Settings → Environment Variables → "Production" scope
# pointing at your Railway backend, e.g.
#   https://loteria-backend.up.railway.app/api
#
# The trailing `/api` matters — main.ts on the backend sets that as its
# global prefix.
VITE_API_BASE_URL=http://localhost:3000/api
